.page { padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom)); background: radial-gradient(circle at 20% 0%, #eef6ff 0%, #f7f8fa 40%); min-height: 100vh; }
.card { background: #fff; border-radius: 20rpx; padding: 20rpx; margin-bottom: 20rpx; box-shadow: 0 10rpx 26rpx rgba(17, 24, 39, 0.06); }
.subtitle { font-size: 28rpx; font-weight: 700; margin-bottom: 12rpx; word-break: break-word; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 12rpx; margin-bottom: 10rpx; }
.ph { font-size: 22rpx; color: #94a3b8; }
.meta { display: flex; flex-wrap: wrap; align-items: center; gap: 12rpx; margin-top: 10rpx; }
.pill { font-size: 22rpx; padding: 6rpx 10rpx; border-radius: 999rpx; background: #eff6ff; color: #1d4ed8; }
.pill-ghost { background: #f1f5f9; color: #0f172a; }
.small { font-size: 24rpx; color: #64748b; word-break: break-word; }
.error { color: #dc2626; }

.product-hero { display: flex; gap: 16rpx; }
.hero-img { width: 210rpx; height: 210rpx; flex: 0 0 210rpx; border-radius: 18rpx; background: #f1f5f9; }
.hero-ph { display: flex; align-items: center; justify-content: center; background: #f1f5f9; }
.hero-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; }
.title { font-size: 30rpx; font-weight: 800; color: #111827; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.hero-price { display: flex; align-items: baseline; gap: 10rpx; margin-top: 10rpx; }
.hero-price-num { font-size: 46rpx; font-weight: 900; color: #111827; letter-spacing: 1rpx; }
.hero-price-sub { opacity: 0.8; }

.actions { display: flex; gap: 12rpx; margin-top: 18rpx; }
.btn { flex: 1; background: linear-gradient(90deg,#2563eb,#0ea5e9); color: #fff; border-radius: 12rpx; font-size: 26rpx; }
.btn-ghost { background: #fff; color: #2563eb; border: 1rpx solid #bfdbfe; }

.chart { width: 100%; border-radius: 16rpx; overflow: hidden; }
.empty { padding: 24rpx; border: 1rpx dashed #e5e7eb; border-radius: 16rpx; background: #fafafa; }
.empty-title { font-size: 28rpx; font-weight: 700; color: #111827; margin-bottom: 6rpx; }

.list .row { display: flex; justify-content: space-between; padding: 10rpx 0; border-bottom: 1rpx solid #f1f5f9; gap: 12rpx; align-items: center; }
.row-left { flex: 1; min-width: 0; }
.val { font-weight: 800; color: #111827; }
.ellipsis { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }

/* Related list styling (reuse compare list look). */
.grid { display: flex; flex-direction: column; gap: 16rpx; }
.result { display: flex; gap: 16rpx; border: 1rpx solid #eef2f7; border-radius: 16rpx; padding: 14rpx; background: #fff; }
.thumb { width: 180rpx; height: 180rpx; flex: 0 0 180rpx; border-radius: 12rpx; background: #f1f5f9; }
.name { font-size: 28rpx; font-weight: 600; color: #111827; }
.platform { font-size: 24rpx; color: #6b7280; }
.dot { color: #cbd5e1; }
.price-line { display: flex; justify-content: flex-start; align-items: baseline; margin-top: 8rpx; }
