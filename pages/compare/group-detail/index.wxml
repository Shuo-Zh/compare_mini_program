<view class="page">
  <view class="card">
    <view class="section-head">
      <view class="subtitle">同款比价</view>
      <view class="pill pill-ghost">{{groupInfo.groupId}}</view>
    </view>
    <view wx:if="{{loading}}" class="loading">
      <text class="small">正在爬取各网站价格，请稍候...</text>
    </view>
    <view wx:elif="{{error}}" class="error-card">
      <view class="error">{{error}}</view>
    </view>
    <view wx:elif="{{products.length}}" class="grid">
      <view wx:for="{{products}}" wx:for-index="idx" wx:key="url" class="result" bindtap="onProductTap" data-idx="{{idx}}">
        <view class="result-card">
          <image wx:if="{{item.image && (item.image.startsWith('https://') || item.image.startsWith('http://'))}}" class="thumb" src="{{item.image}}" mode="aspectFill" lazy-load="true" binderror="onImgError" data-idx="{{idx}}" />
          <view wx:else class="thumb thumb-ph"><text class="ph">No Image</text></view>
          <view class="info">
            <view class="name ellipsis" bindtap="onShowTitle" data-title="{{item.title}}">{{item.title}}</view>
            <view class="meta">
              <text class="platform">{{item.platform}}</text>
              <text class="dot">·</text>
              <text class="small">{{item.id}}</text>
            </view>
            <view class="price-line">
              <text class="price">¥{{item.priceCny || item.price}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty">
      <view class="empty-title">暂无比价数据</view>
      <view class="small">点击刷新按钮重新爬取</view>
    </view>
  </view>
  
  <view class="actions">
    <button class="btn" bindtap="onRefresh" loading="{{loading}}" disabled="{{loading}}">刷新比价</button>
    <button class="btn btn-ghost" bindtap="onBack">返回</button>
  </view>
</view>