.page { padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom)); background: radial-gradient(circle at 20% 0%, #eef6ff 0%, #f7f8fa 40%); min-height: 100vh; }
.card { background: #fff; border-radius: 20rpx; padding: 20rpx; margin-bottom: 20rpx; box-shadow: 0 6rpx 16rpx rgba(17, 24, 39, 0.05); }
.subtitle { font-size: 28rpx; font-weight: 700; margin-bottom: 12rpx; word-break: break-word; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 12rpx; margin-bottom: 6rpx; }
.pill { font-size: 22rpx; padding: 6rpx 10rpx; border-radius: 999rpx; background: #eff6ff; color: #1d4ed8; }
.pill-ghost { background: #f1f5f9; color: #0f172a; }
.small { font-size: 24rpx; color: #64748b; }
.loading { padding: 40rpx 0; text-align: center; }
.error { color: #dc2626; margin-bottom: 16rpx; }
.empty { padding: 40rpx 0; text-align: center; }
.empty-title { font-size: 28rpx; font-weight: 700; color: #111827; margin-bottom: 8rpx; }

.grid { display: flex; flex-wrap: wrap; margin: -8rpx; }
.result { width: 50%; padding: 8rpx; box-sizing: border-box; }
.result-card { display: flex; flex-direction: column; gap: 10rpx; border: 1rpx solid #eef2f7; border-radius: 16rpx; padding: 12rpx; background: #fff; overflow: hidden; height: 100%; }
.thumb { width: 100%; height: 260rpx; flex: 0 0 auto; border-radius: 12rpx; background: #e5e7eb; }
.thumb-ph { display: flex; align-items: center; justify-content: center; background: #f1f5f9; }
.ph { font-size: 22rpx; color: #94a3b8; }
.info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: flex-start; overflow: hidden; }
.name {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-all;
  line-height: 1.4;
}
.meta { display: flex; align-items: center; gap: 10rpx; margin-top: 6rpx; }
.dot { color: #cbd5e1; }
.platform { font-size: 20rpx; color: #6b7280; }
.price-line { display: flex; align-items: center; margin-top: auto; padding-top: 8rpx; flex-wrap: nowrap; }
.price { min-width: 100rpx; white-space: nowrap; flex: 0 0 auto; font-weight: 700; color: #111827; }

.actions { display: flex; gap: 12rpx; margin-top: 18rpx; }
.btn { flex: 1; background: linear-gradient(90deg,#2563eb,#0ea5e9); color: #fff; border-radius: 12rpx; font-size: 26rpx; }
.btn-ghost { background: #fff; color: #2563eb; border: 1rpx solid #bfdbfe; }