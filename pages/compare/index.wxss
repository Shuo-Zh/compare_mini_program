.page { padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom)); background: radial-gradient(circle at 20% 0%, #eef6ff 0%, #f7f8fa 40%); min-height: 100vh; }
.card { background: #fff; border-radius: 20rpx; padding: 20rpx; margin-bottom: 20rpx; box-shadow: 0 6rpx 16rpx rgba(17, 24, 39, 0.05); }
.nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14rpx; }
.nav-left, .nav-right { width: 60rpx; }
.nav-title { flex: 1; min-width: 0; text-align: center; font-size: 34rpx; font-weight: 800; letter-spacing: 1rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.subtitle { font-size: 28rpx; font-weight: 700; margin-bottom: 12rpx; word-break: break-word; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 12rpx; margin-bottom: 6rpx; }
.section-hint { font-size: 22rpx; color: #94a3b8; white-space: nowrap; }
.subline { font-size: 24rpx; color: #64748b; margin-top: -6rpx; margin-bottom: 10rpx; }
.ipt { border: 1rpx solid #e5e7eb; border-radius: 12rpx; padding: 16rpx; font-size: 28rpx; margin-bottom: 12rpx; }
.search { display: flex; gap: 14rpx; align-items: center; }
.ipt-search { flex: 1; margin-bottom: 0; border-radius: 999rpx; padding-left: 22rpx; }
.btn { background: linear-gradient(90deg,#2563eb,#0ea5e9); color: #fff; border-radius: 12rpx; }
.btn-search { width: 160rpx; border-radius: 999rpx; }
.search-actions { display: flex; justify-content: flex-end; margin-top: 12rpx; }
.clear { font-size: 24rpx; color: #64748b; padding: 6rpx 10rpx; border: 1rpx solid #e5e7eb; border-radius: 999rpx; }
.devbar { display: flex; justify-content: space-between; align-items: center; gap: 12rpx; margin-top: 14rpx; }
.devleft { flex: 1; min-width: 0; font-size: 24rpx; color: #64748b; }
.devright { display: flex; align-items: center; gap: 10rpx; }
.devlink { font-size: 24rpx; color: #2563eb; text-decoration: underline; }
.devsep { font-size: 24rpx; color: #cbd5e1; }
.devpanel { margin-top: 12rpx; }
.devactions { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.devtoggle { display: flex; align-items: center; gap: 12rpx; }
.btn-ghost { background: #fff; color: #2563eb; border: 1rpx solid #bfdbfe; }
.error { color: #dc2626; margin-bottom: 16rpx; }
.chart { width: 100%; }
.chart-wrap { overflow: hidden; border-radius: 16rpx; }
.subtitle-tight { margin-top: 6rpx; margin-bottom: 10rpx; }
.list .row { display: flex; justify-content: space-between; padding: 10rpx 0; border-bottom: 1rpx solid #f1f5f9; }
.list .row { align-items: center; gap: 12rpx; }
.row-left { flex: 1; min-width: 0; }
.price { font-weight: 700; color: #111827; }
.warn { color: #b45309; }
.small { font-size: 24rpx; color: #64748b; }
.warn-text { color: #b45309; }
.stats .row { padding: 6rpx 0; }

.grid { display: flex; flex-wrap: wrap; margin: -8rpx; }
.result { width: 50%; padding: 8rpx; box-sizing: border-box; }
.result-card { display: flex; flex-direction: column; gap: 10rpx; border: 1rpx solid #eef2f7; border-radius: 16rpx; padding: 12rpx; background: #fff; overflow: hidden; height: 100%; }
.thumb { width: 100%; height: 260rpx; flex: 0 0 auto; border-radius: 12rpx; background: #e5e7eb; }
.thumb-ph { display: flex; align-items: center; justify-content: center; background: #f1f5f9; }
.ph { font-size: 22rpx; color: #94a3b8; }
.info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: flex-start; overflow: hidden; }
.name {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-all;
  line-height: 1.4;
}
.title-hover { opacity: 0.7; }
.ellipsis { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.meta { display: flex; align-items: center; gap: 10rpx; margin-top: 6rpx; }
.dot { color: #cbd5e1; }
.price-line { display: flex; align-items: center; margin-top: auto; padding-top: 8rpx; flex-wrap: nowrap; }
.price { min-width: 100rpx; white-space: nowrap; flex: 0 0 auto; }
.platform { font-size: 20rpx; color: #6b7280; }
.link { color: #2563eb; text-decoration: underline; }
.group { font-size: 22rpx; padding: 2rpx 10rpx; border-radius: 999rpx; background: #f1f5f9; color: #0f172a; }
.evidence-row { margin-top: 8rpx; margin-bottom: 8rpx; display: flex; }
.pill-link { font-size: 22rpx; padding: 8rpx 12rpx; border-radius: 999rpx; background: #eff6ff; color: #1d4ed8; border: 1rpx solid #bfdbfe; }

/* Keep a single-column list for smoother scrolling. */
